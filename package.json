{
  "name": "claudecontrolai",
  "version": "0.2.1",
  "description": "A local dashboard for your Claude Code sessions — live activity, history, and cost, in your browser.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "claudecontrolai": "bin/cli.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "dashboard",
    "cli",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaeel29/claude-control.git"
  },
  "files": [
    "bin",
    ".output"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3001",
    "start": "node bin/cli.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepublishOnly": "nuxt build",
    "postinstall": "node -e \"process.exit(require('fs').existsSync('nuxt.config.ts')&&!require('fs').existsSync('.output')?0:1)\" && nuxt prepare || true"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.1",
    "nuxt": "^4.2.1",
    "uqr": "^0.1.2",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@types/node": "^25.5.0",
    "sass-embedded": "^1.93.3"
  }
}
