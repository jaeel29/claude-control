{
  "name": "claude-control",
  "version": "0.1.0",
  "description": "Local dashboard to monitor and control your Claude Code sessions — with optional remote (Tailscale) access from your phone.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "claude-control": "bin/cli.mjs"
  },
  "files": [
    "bin",
    ".output"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3001",
    "start": "node bin/cli.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepublishOnly": "nuxt build",
    "postinstall": "node -e \"process.exit(require('fs').existsSync('nuxt.config.ts')&&!require('fs').existsSync('.output')?0:1)\" && nuxt prepare || true"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.1",
    "nuxt": "^4.2.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@types/node": "^25.5.0",
    "sass-embedded": "^1.93.3"
  }
}
